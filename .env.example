# Copie ce fichier en .env et remplis les valeurs

# URL de connexion PostgreSQL (locale)
DATABASE_URL=postgresql://postgres:motdepasse@localhost:5432/trello2

# Clé secrète JWT (change-la en production !)
JWT_SECRET=trello2-local-secret-change-en-prod

# Environnement
NODE_ENV=development

# Port du serveur (optionnel, défaut: 3001)
PORT=3001
